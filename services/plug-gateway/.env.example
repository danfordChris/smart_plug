# Plug Assistance gateway configuration.
# Copy to `.env` (local) or `deploy/gateway/gateway.env` (Pi) and fill in real
# values. NEVER commit real secrets — only this example with variable names.

# Upstream Home Assistant (the Pi). On the Pi host itself, localhost works.
HA_BASE_URL=http://localhost:8123

# Long-lived HA access token. This lives ONLY here, server-side, and is never
# sent to app clients. Generate in HA: Profile -> Security -> Long-Lived Tokens.
HA_TOKEN=replace-with-home-assistant-long-lived-token

# Secret used to sign per-user JWTs. Use 32+ random bytes:
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-32-byte-random-secret

# Token lifetimes.
ACCESS_TTL_MINUTES=30
REFRESH_TTL_DAYS=30

# SQLite path (mount a persistent host volume at /data in production).
DB_PATH=/data/plug_gateway.db
