# Plug Assistance gateway configuration.
# Copy to `.env` (local) or `deploy/gateway/gateway.env` (Pi) and fill in real
# values. NEVER commit real secrets — only this example with variable names.

# Upstream Home Assistant (the Pi). On the Pi host itself, localhost works.
HA_BASE_URL=http://localhost:8123

# Long-lived HA access token. This lives ONLY here, server-side, and is never
# sent to app clients. Generate in HA: Profile -> Security -> Long-Lived Tokens.
HA_TOKEN=replace-with-home-assistant-long-lived-token

# Secret used to sign per-user JWTs. Use 32+ random bytes:
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-32-byte-random-secret

# Token lifetimes.
ACCESS_TTL_MINUTES=30
REFRESH_TTL_DAYS=30

# SQLite path (mount a persistent host volume at /data in production).
DB_PATH=/data/plug_gateway.db

# Timezone for schedules (IANA name).
TIMEZONE=Africa/Dar_es_Salaam

# Firebase Cloud Messaging (push). Path to a Firebase service-account JSON,
# mounted into the container (e.g. /data/fcm-service-account.json). Leave empty
# to disable push — the in-app alerts feed still works. project_id is read from
# the JSON unless FCM_PROJECT_ID is set.
FCM_CREDENTIALS_FILE=
FCM_PROJECT_ID=

# Appliance-diagnosis ML. Model artifacts persist on the /data volume.
ML_MODELS_DIR=/data/models
# Electricity tariff for cost diagnosis (mirror the app's AppConstants).
TARIFF_PER_KWH=500
CURRENCY_SYMBOL=TSh

# Cloudflare Tunnel token (production only) — exposes the gateway on a public
# subdomain over HTTPS with no open ports. Create a tunnel in the Cloudflare
# Zero Trust dashboard, add a Public Hostname for your subdomain pointing to
# http://localhost:8099, and paste the token here. See deploy/gateway/DOMAIN-SETUP.md.
TUNNEL_TOKEN=
